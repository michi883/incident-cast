# Gemini API key for the specialist agents.
GEMINI_API_KEY=

# Splunk Enterprise connection (used at M2+).
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=
SPLUNK_HEC_URL=https://localhost:8088
SPLUNK_HEC_TOKEN=
SPLUNK_VERIFY_TLS=false

# Query backend: fixture | sdk | mcp
INCIDENTCAST_BACKEND=fixture
INCIDENTCAST_FIXTURE_DIR=data/fixtures/cloud_run_secret_loss

# Model used by the specialists.
INCIDENTCAST_MODEL=gemini-3.1-pro-preview

# Splunk MCP Server (M3). Generated by scripts/setup_splunk_mcp.sh.
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
SPLUNK_MCP_TOKEN=
